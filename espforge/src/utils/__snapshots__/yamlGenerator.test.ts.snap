exports[`generateYaml — template golden files > generates stable YAML for "power_monitor" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# Sensors
sensor:
  - platform: hlw8012
    voltage:
      name: Voltage
    current:
      name: Current
    power:
      name: Power
    current_resistor: 0.001
    voltage_divider: 2351
    update_interval: 10s
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;

exports[`generateYaml — template golden files > generates stable YAML for "presence_sensor" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# UART bus
uart:
  - baud_rate: 256000
    parity: NONE
    stop_bits: 1
    id: sensor_1_uart

# LD2410 mmWave radar
ld2410:
  uart_id: sensor_1_uart
  max_move_distance_gate: 8
  max_still_distance_gate: 8
  timeout: 5

# Sensors
sensor:
  - platform: ld2410
    moving_distance:
      name: Moving Distance
    still_distance:
      name: Still Distance
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Switches
switch:
  - platform: gpio
    name: Light
    id: switch_2
    restore_mode: RESTORE_DEFAULT_OFF

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart

# Binary sensors
binary_sensor:
  - platform: ld2410
    has_target:
      name: Presence
    has_moving_target:
      name: Moving Target
    has_still_target:
      name: Still Target
"
`;

exports[`generateYaml — template golden files > generates stable YAML for "smart_relay" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP8266 board settings
esp8266:
  board: esp01_1m
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# Outputs
output:
  - platform: gpio
    pin: GPIO13
    id: dc_3
    inverted: true

# Switches
switch:
  - platform: gpio
    pin:
      number: GPIO12
    name: Relay
    id: switch_1
    restore_mode: RESTORE_DEFAULT_OFF

# Binary sensors
binary_sensor:
  - platform: gpio
    pin:
      number: GPIO0
      mode:
        input: true
    name: Button
    device_class: None
    on_press:
      then:
        - switch.toggle: switch_1

# Sensors
sensor:
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;
