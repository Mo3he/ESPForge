exports[`generateYaml — template golden files > generates stable YAML for "motion_light" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# Binary sensors
binary_sensor:
  - platform: gpio
    pin:
      mode:
        input: true
    name: Motion
    device_class: motion
    on_press:
      then:
        - switch.turn_on: switch_2
    on_release:
      then:
        - delay: 2min
        - switch.turn_off: switch_2

# Switches
switch:
  - platform: gpio
    name: Light
    id: switch_2
    restore_mode: RESTORE_DEFAULT_OFF

# Sensors
sensor:
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;

