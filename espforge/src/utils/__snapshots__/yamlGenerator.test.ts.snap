exports[`generateYaml — template golden files > generates stable YAML for "environment_monitor" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# I²C bus
i2c:
  sda: GPIO21
  scl: GPIO22
  scan: true

# Sensors
sensor:
  - platform: bme280_i2c
    address: "0x76"
    temperature:
      name: Temperature
    humidity:
      name: Humidity
    pressure:
      name: Pressure
    update_interval: 60s
  - platform: scd4x
    co2:
      name: CO2
    temperature:
      name: SCD41 Temp
    humidity:
      name: SCD41 Humidity
    update_interval: 60s
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;

exports[`generateYaml — template golden files > generates stable YAML for "fan_controller" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# Fans
fan:
  - platform: speed
    name: Fan
    output: fan_1_output
    speed_count: 4

# Binary sensors
binary_sensor:
  - platform: gpio
    pin:
      mode:
        input: true
    name: Fan Button
    device_class: None

# Sensors
sensor:
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart

# Outputs
output:
  - platform: ledc
    pin: GPIOXX
    id: fan_1_output
    frequency: 1000Hz
"
`;

exports[`generateYaml — template golden files > generates stable YAML for "garage_door" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# Covers / Blinds
cover:
  - platform: time_based
    name: Garage Door
    device_class: garage
    open_action:
      - switch.turn_on: cover_1_open
    open_duration: 15s
    close_action:
      - switch.turn_on: cover_1_close
    close_duration: 15s
    stop_action:
      - switch.turn_off: cover_1_open
      - switch.turn_off: cover_1_close

# Binary sensors
binary_sensor:
  - platform: gpio
    pin:
      mode:
        input: true
    name: Door Open
    device_class: garage_door

# Sensors
sensor:
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;

exports[`generateYaml — template golden files > generates stable YAML for "ir_blaster" 1`] = `
"# Device configuration
esphome:
  name: test-device
  friendly_name: Test Device

# ESP32 board settings
esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Home Assistant API
api:
  encryption:
    key: AABBCCDDEEFF00112233445566778899AABBCCDDEEFF001122334455667788

# Over-the-Air updates
ota:
  - platform: esphome

# WiFi configuration
wifi:
  ssid: TestNetwork
  password: test-password
  ap:
    ssid: Test Device Fallback
    password: fallback123

# Captive portal (for WiFi setup fallback)
captive_portal:

# IR transmitter
remote_transmitter:
  - carrier_duty_percent: 50%
    id: ir_1

# IR receiver
remote_receiver:
  - dump: all
    tolerance: 25%
    id: ir_2

# Climate / HVAC
climate:
  - platform: daikin
    name: Air Conditioner
    transmitter_id: ir_1

# Sensors
sensor:
  - platform: wifi_signal
    name: WiFi Signal
    update_interval: 60s
  - platform: uptime
    name: Uptime

# Text sensors
text_sensor:
  - platform: wifi_info
    ip_address:
      name: IP Address
    ssid:
      name: Connected SSID

# Buttons
button:
  - platform: restart
    name: Restart
"
`;

